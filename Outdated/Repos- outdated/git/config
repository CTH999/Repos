[core]
	repositoryformatversion = 0
	filemode = false
	bare = false
	logallrefupdates = true
	symlinks = false
	ignorecase = true
[submodule]
	active = .
[remote "origin"]
	url = https://github.com/CTH-npitx/Repos.git
	fetch = +refs/heads/*:refs/remotes/origin/*
[branch "main"]
	remote = origin
	merge = refs/heads/main
[lfs]
	repositoryformatversion = 0
[remote "upstream"]
	url = https://github.com/CTH999/Repos.git
	fetch = +refs/heads/*:refs/remotes/upstream/*
[branch "move-files"]
	remote = origin
	merge = refs/heads/move-files
